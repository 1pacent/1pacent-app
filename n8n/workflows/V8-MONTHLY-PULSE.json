{
  "name": "V8-MONTHLY-PULSE",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "months", "triggerAtDayOfMonth": 1, "triggerAtHour": 9 }]
        }
      },
      "id": "cron-monthly",
      "name": "Monthly 1st 9am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.APP_BASE_URL }}/api/internal/monthly-pulse",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "X-Internal-Auth", "value": "={{ $env.N8N_INTERNAL_AUTH_TOKEN }}" }
          ]
        },
        "options": { "timeout": 60000 }
      },
      "id": "call-pulse",
      "name": "Send Monthly Pulse",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0]
    }
  ],
  "connections": {
    "Monthly 1st 9am": { "main": [[{ "node": "Send Monthly Pulse", "type": "main", "index": 0 }]] }
  },
  "settings": {}
}
