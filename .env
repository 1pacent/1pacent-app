# 1pacent App — Environment Configuration
# Copy this to .env in the project root before building

# n8N API Configuration
N8N_BASE_URL=https://api.1pacent.com
N8N_FALLBACK_BASE_URL=http://172.18.0.2:5678

# API Base URL (for direct API calls bypassing n8n)
API_BASE_URL=https://api.1pacent.com

# Feature Flags
ENABLE_SALLY_CHAT=true
ENABLE_NOTIFICATIONS=true
ENABLE_FILE_UPLOAD=true
ENABLE_GEOCODING=true

# Auth
AUTH_MODE=demo
