# Copy to .env.local. The app switches from demo data to Supabase as soon
# as NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are both set
# (set DATA_SOURCE=demo to force the seeded demo org regardless).
NEXT_PUBLIC_SUPABASE_URL=https://yxgvvbfsbvykmsqzuzxi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never exposed to the client bundle:
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DATA_SOURCE=
# Internal n8n worker (API tier -> n8n only; no public ingress):
N8N_INTERNAL_URL=
N8N_INTERNAL_AUTH_TOKEN=

# Sally (conversational intake) — OpenRouter for chat + embeddings, server-only:
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
# Sally's voice (TTS-out only, no mic/STT input):
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Used by the deployed app to build tradie quote-link URLs sent via n8n:
APP_BASE_URL=

# ── The owned AI layer (Product Brief v7) — all optional; leaving them unset
#    keeps the direct-OpenRouter / pgvector behaviour, identical semantics. ──
# Hermes agent runtime: set HERMES_URL to route all Sally reasoning through it
# (one place to swap models, cap spend, log tokens). OPENAI_COMPAT=1 → full
# tool loop via {url}/v1/chat/completions; unset → {url}/agents/sally/invoke
# for plain chat, tool turns fall back to OpenRouter (logged, honest).
HERMES_URL=
HERMES_API_KEY=
HERMES_AGENT=sally
HERMES_OPENAI_COMPAT=
# Honcho memory substrate (peers=contacts, sessions=conversations). Facts about
# money/dates/compliance/assets are refused at the boundary — the DB is truth.
HONCHO_BASE_URL=
HONCHO_API_KEY=
# Qdrant vector store (cosine, 1536-dim, collection per org). Unset → pgvector.
QDRANT_URL=
QDRANT_API_KEY=
