# Copy to .env.local when wiring Supabase (Sydney project).
# Until these are set the app runs in demo mode on seeded data.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — never exposed to the client bundle:
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
# Internal n8n worker (API tier -> n8n only; no public ingress):
N8N_INTERNAL_URL=
N8N_INTERNAL_AUTH_TOKEN=
