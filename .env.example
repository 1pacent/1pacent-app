# =============================================================================
# 1Pacent — Root Environment Example
# Copy to .env for local/VPS dev. The web app has its own .env.local in apps/web/.
# =============================================================================

# --- PostgreSQL (Docker Compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change...N8N_ENCRYPTION_KEY=change-me-too

# --- Supabase (hosted, Sydney region) ---
# Copy from apps/web/.env.example
NEXT_PUBLIC_SUPABASE_URL=https://yxgvvbfsbvykmsqzuzxi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
DATABASE_URL=
DATA_SOURCE=demo

# --- n8n (Docker Compose or shared instance) ---
N8N_INTERNAL_URL=http://n8n:5678/
N8N_INTERNAL_AUTH_TOKEN=

# --- AI / Hermes ---
OPENROUTER_API_KEY=
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# --- App ---
APP_BASE_URL=http://localhost:3000


# --- v8 R2: Moments over Web Push (generate with web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:mac@1pacent.com

# --- v8 R2: Hermes memory / tone (optional; degrades gracefully) ---
HONCHO_BASE_URL=
HONCHO_API_KEY=

# --- v8 R3: real money (optional; simulated PSP without them) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
